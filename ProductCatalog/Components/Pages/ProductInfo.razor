@page "/ProductInfo/{Id:int}"
@rendermode InteractiveServer
@inject NavigationManager NavigationManager
@inject IProductApiService ProductApiService
@inject IShareMessageBuilder ShareMessageBuilder
@inject IAddedItemsService AddedItemsService
@using ProductCatalog.Web.Business.IService
@using ProductCatalog.Web.Utility.Model

@* Meijer Blue Header Layout *@
<div class="row justify-content-center">
    <div class="col-md-8">
        @if (isLoading)
        {
            <div class="text-center py-5">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading product details...</span>
                </div>
            </div>
        }
        else if (productDetail == null)
        {
            <div class="alert alert-warning text-center shadow-sm" role="alert">
                <i class="bi bi-exclamation-triangle-fill fs-4 d-block mb-2"></i>
                Product details could not be found or loaded.
            </div>
        }
        else
        {
            <div class="card shadow border-0 overflow-hidden">
                <div class="bg-light text-center border-bottom position-relative" style="min-height: 250px; max-height: 320px;">
                    @if (!string.IsNullOrEmpty(productDetail.ImageUrl))
                    {
                        <img src="@productDetail.ImageUrl" class="img-fluid w-100 h-100 object-fit-contain p-2" alt="@productDetail.Title" style="max-height: 300px;" />
                    }
                    else
                    {
                        <div class="d-flex flex-column align-items-center justify-content-center h-100 py-5 text-muted">
                            <i class="bi bi-image" style="font-size: 5rem;"></i>
                            <span class="mt-2 font-weight-bold">Full Image Placeholder</span>
                        </div>
                    }
                </div>

                <div class="card-body p-4">
                    
                    <h3 class="card-title text-dark font-weight-bold mb-3">
                        <span class="text-muted small d-block text-uppercase font-weight-normal mb-1">Title</span>
                        @productDetail.Title
                    </h3>

                    <div class="mb-4">
                        <span class="text-muted small d-block text-uppercase mb-1">Description</span>
                        <p class="card-text text-secondary lh-base" style="white-space: pre-line;">
                            @(string.IsNullOrEmpty(productDetail.Description) ? productDetail.Summary : productDetail.Description)
                        </p>
                    </div>

                    <div class="mb-4">
                        <span class="text-muted small d-block text-uppercase mb-1">Price</span>
                        <h2 class="text-success font-weight-bold m-0">@productDetail.Price</h2>
                    </div>

                    @if (!showCityPrompt)
                    {
                        <div class="d-flex flex-wrap align-items-center gap-3 pt-3 border-top">
                            <button class="btn btn-primary d-inline-flex align-items-center px-4 py-2" @onclick="StartAddToList" style="background-color: #0c60a5; border-color: #0c60a5;">
                                <i class="bi bi-plus-lg me-2"></i> Add to List
                            </button>

                            <button class="btn btn-primary d-inline-flex align-items-center px-4 py-2" style="background-color: #0c60a5; border-color: #0c60a5;" @onclick="GoBack">
                                <i class="bi bi-plus-lg me-2"></i> Back to Catalog
                            </button>
                        </div>
                    }
                    else
                    {
                        <div class="pt-3 border-top">
                            <label for="cityInput" class="font-weight-bold text-muted small mb-2 text-uppercase d-block">
                                What city should we list you as being in?
                            </label>
                            <div class="input-group" style="max-width: 420px;">
                                <input id="cityInput" class="form-control" placeholder="e.g. Chicago" @bind="cityInput" @bind:event="oninput" @onkeyup="OnCityInputKeyUp" />
                                <button class="btn btn-primary" style="background-color: #0c60a5; border-color: #0c60a5;" @onclick="ConfirmAddToList" disabled="@(string.IsNullOrWhiteSpace(cityInput))">
                                    Confirm
                                </button>
                                <button class="btn text-white" style="background-color: #0c60a5; border-color: #0c60a5;" @onclick="CancelAddToList">
                                    Cancel
                                </button>
                            </div>
                            @if (!string.IsNullOrEmpty(cityValidationError))
                            {
                                <div class="text-danger small mt-2">@cityValidationError</div>
                            }
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(statusMessage))
                    {
                        <div class="alert @statusCssClass mt-3 mb-0 py-2 small" role="status">
                            @statusMessage
                        </div>
                    }
                    @if (showMailtoFallback && !string.IsNullOrEmpty(lastShareMessage))
                    {
                        <div class="mt-2">
                            <a class="small" href="@BuildMailtoLink()">
                                <i class="bi bi-envelope me-1"></i> Or send it by email instead
                            </a>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>

@* Embedded Custom Utilities Constraints *@
<style>
    .object-fit-contain {
        object-fit: contain;
    }

    .font-weight-bold {
        font-weight: 700;
    }

    .font-weight-normal {
        font-weight: 400;
    }
</style>

@code {
    [Parameter]
    public int Id { get; set; }

    private ProductDetail? productDetail;
    private bool isLoading = true;

    private bool showCityPrompt;
    private string cityInput = string.Empty;
    private string? cityValidationError;

    private string? lastShareMessage;
    private string? statusMessage;
    private string statusCssClass = "alert-success";
    private bool showMailtoFallback;

    protected override async Task OnParametersSetAsync()
    {
        try
        {
            isLoading = true;
            statusMessage = null;
            showCityPrompt = false;
            productDetail = await ProductApiService.GetProductDetailsAsync(Id);
        }
        catch (Exception)
        {
            productDetail = null;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/");
    }

    private void StartAddToList()
    {
        showCityPrompt = true;
        cityValidationError = null;
        statusMessage = null;
        showMailtoFallback = false;
    }

    private void CancelAddToList()
    {
        showCityPrompt = false;
        cityInput = string.Empty;
        cityValidationError = null;
    }

    private async Task OnCityInputKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(cityInput))
        {
            await ConfirmAddToList();
        }
    }

    private async Task ConfirmAddToList()
    {
        if (productDetail is null)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(cityInput))
        {
            cityValidationError = "Please enter a city.";
            return;
        }

        cityValidationError = null;

        var message = ShareMessageBuilder.BuildAddToListMessage(productDetail.Title, productDetail.Price, cityInput);

        AddedItemsService.Add(new AddedListItem
        {
            ProductId = productDetail.Id,
            Title = productDetail.Title,
            City = cityInput.Trim(),
            ShareMessage = message
        });

        lastShareMessage = message;
        showCityPrompt = false;
        statusMessage = $"Added to list: \"{message}\"";
        statusCssClass = "alert-info";
        showMailtoFallback = true;
    }
    private string BuildMailtoLink()
    {
        var body = Uri.EscapeDataString(lastShareMessage ?? string.Empty);
        var subject = Uri.EscapeDataString("Product I added to my list");
        return $"mailto:?subject={subject}&body={body}";
    }
}
